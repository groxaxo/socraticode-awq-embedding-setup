PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=8000
TARGET_HOST=127.0.0.1
TARGET_PORT=18000
IDLE_SECONDS=60
START_TIMEOUT_SECONDS=300
HEALTH_PATH=/v1/models

GPU_DEVICE=0
MODEL_NAME=drawais/Qwen3-Embedding-4B-AWQ-INT4
SERVED_MODEL_NAME=drawais/Qwen3-Embedding-4B-AWQ-INT4
RUNNER=pooling
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.88
VLLM_BIN=/home/op/miniconda3/envs/vllm/bin/vllm

# systemd EnvironmentFile values are not shell templates. Keep this command explicit.
START_CMD="CUDA_DEVICE_ORDER=PCI_BUS_ID CUDA_VISIBLE_DEVICES=0 /home/op/miniconda3/envs/vllm/bin/vllm serve drawais/Qwen3-Embedding-4B-AWQ-INT4 --host 127.0.0.1 --port 18000 --runner pooling --convert embed --max-model-len 32768 --gpu-memory-utilization 0.88"
